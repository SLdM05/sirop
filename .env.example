# Copy to .env and fill in your values
BTC_NODE_BACKEND=mempool
BTC_RPC_URL=http://127.0.0.1:8332
BTC_RPC_USER=
BTC_RPC_PASSWORD=
BTC_MEMPOOL_URL=http://localhost:3006/api
# Maximum on-chain hops for UTXO graph traversal when searching for
# unmatched transfer pairs.  0 = disabled (default, no API calls made).
# Increase to 3-5 if you have multi-hop transfers (CPFP, consolidation, etc.).
BTC_TRAVERSAL_MAX_HOPS=0
# Set to true ONLY if you accept the privacy risk of sending txids to a public
# Mempool endpoint.  Skips the interactive Y/n prompt in that case.
# Has no effect when BTC_MEMPOOL_URL is a local/private address (no prompt shown).
BTC_TRAVERSAL_ALLOW_PUBLIC=false
DATA_DIR=./data
OUTPUT_DIR=./output

# CoinGecko Demo API key (optional, but recommended).
# Without a key, the unauthenticated public API is used — it has stricter
# rate limits and may intermittently return no price data for some dates.
# Get a free Demo key at https://www.coingecko.com/en/api (no credit card).
COINGECKO_API_KEY=

# Cross-batch asset price cache (optional).
# When true, sirop stores fetched BoC rates and crypto prices in a shared
# SQLite file (DATA_DIR/.sirop_price_cache) so new batches reuse prices
# already fetched by previous batches.  Safe to enable for most users.
ASSET_PRICE_CACHE=false
